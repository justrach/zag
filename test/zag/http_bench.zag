//! High-performance HTTP server using thread pool + connection queue.
//! Matches TurboAPI's architecture exactly: accept loop → queue → worker threads.
//!
//! Build: test/zag/build.sh http_bench ReleaseFast
//! Bench: wrk -t4 -c200 -d10s http://127.0.0.1:8080/

const std = @import("std");
const net = std.net;
const Thread = std.Thread;

const response_200 = "HTTP/1.1 200 OK\r\nContent-Type: application/json\r\nContent-Length: 27\r\nConnection: keep-alive\r\n\r\n{\"message\":\"Hello, World!\"}";
const response_404 = "HTTP/1.1 404 Not Found\r\nContent-Type: application/json\r\nContent-Length: 22\r\nConnection: close\r\n\r\n{\"error\":\"Not Found\"}";

var total_requests: std.atomic.Value(u64) = std.atomic.Value(u64).init(0);

fn handleConnection(stream: net.Stream) void {
    defer stream.close();

    var buf: [4096]u8 = undefined;
    while (true) {
        const n = stream.read(&buf) catch break;
        if (n == 0) break;
        if (n < 16) break;

        // Ultra-minimal route: GET / or GET /hello → 200, else 404
        if (buf[0] == 'G' and buf[4] == '/' and (buf[5] == ' ' or buf[5] == 'h')) {
            stream.writeAll(response_200) catch break;
        } else {
            stream.writeAll(response_404) catch break;
            break;
        }

        _ = total_requests.fetchAdd(1, .release);
    }
}

/// Lock-free connection queue (MPSC: accept thread pushes, workers pop)
const ConnQueue = struct {
    const CAP = 4096;
    items: [CAP]net.Stream = undefined,
    head: usize = 0,
    tail: usize = 0,
    count: usize = 0,
    mutex: Thread.Mutex = .{},
    not_empty: Thread.Condition = .{},

    fn push(self: *ConnQueue, stream: net.Stream) void {
        self.mutex.lock();
        defer self.mutex.unlock();
        if (self.count >= CAP) {
            stream.close();
            return;
        }
        self.items[self.tail] = stream;
        self.tail = (self.tail + 1) % CAP;
        self.count += 1;
        self.not_empty.signal();
    }

    fn pop(self: *ConnQueue) net.Stream {
        self.mutex.lock();
        defer self.mutex.unlock();
        while (self.count == 0) {
            self.not_empty.wait(&self.mutex);
        }
        const stream = self.items[self.head];
        self.head = (self.head + 1) % CAP;
        self.count -= 1;
        return stream;
    }
};

var queue: ConnQueue = .{};

fn workerLoop() void {
    while (true) {
        const stream = queue.pop();
        handleConnection(stream);
    }
}

pub fn main() !void {
    const port: u16 = 8080;
    const cpu_count = Thread.getCpuCount() catch 4;
    const num_workers = cpu_count; // use all cores

    std.debug.print("=== Zag HTTP Server ===\n", .{});
    std.debug.print("Workers: {d} threads\n", .{num_workers});
    std.debug.print("Listening on http://0.0.0.0:{d}\n", .{port});
    std.debug.print("Benchmark: wrk -t4 -c200 -d10s http://127.0.0.1:{d}/\n\n", .{port});

    // Stats thread
    _ = try Thread.spawn(.{}, struct {
        fn run() void {
            var last: u64 = 0;
            while (true) {
                std.Thread.sleep(1 * std.time.ns_per_s);
                const current = total_requests.load(.acquire);
                const rps = current - last;
                last = current;
                std.debug.print("[stats] {d} req/s | {d} total\n", .{ rps, current });
            }
        }
    }.run, .{});

    // Spawn worker threads
    for (0..num_workers) |_| {
        _ = try Thread.spawn(.{}, workerLoop, .{});
    }

    // Accept loop on main thread
    const addr = net.Address.parseIp4("0.0.0.0", port) catch return;
    var server = try addr.listen(.{ .reuse_address = true });
    defer server.deinit();

    while (true) {
        const conn = server.accept() catch continue;
        queue.push(conn.stream);
    }
}
