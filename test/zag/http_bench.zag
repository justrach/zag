//! Sharded-queue HTTP server — zero contention between workers.
//! Accept distributes connections round-robin across per-worker queues.
//!
//! Build: test/zag/build.sh http_bench ReleaseFast
//! Bench: wrk -t8 -c1000 -d10s http://127.0.0.1:8080/

const std = @import("std");
const net = std.net;
const posix = std.posix;
const Thread = std.Thread;

const resp = "HTTP/1.1 200 OK\r\nContent-Type: application/json\r\nContent-Length: 27\r\nConnection: keep-alive\r\n\r\n{\"message\":\"Hello, World!\"}";

var total_requests: std.atomic.Value(u64) = std.atomic.Value(u64).init(0);

inline fn handleConnection(stream: net.Stream) void {
    defer stream.close();
    var buf: [4096]u8 = undefined;
    while (true) {
        const n = stream.read(&buf) catch break;
        if (n == 0) break;
        stream.writeAll(resp) catch break;
        _ = total_requests.fetchAdd(1, .monotonic);
    }
}

/// Per-worker queue — only one producer (accept) and one consumer (worker),
/// so we only need the mutex for the condition wait, not for data integrity.
const WorkerQueue = struct {
    const CAP = 1024;
    items: [CAP]net.Stream = undefined,
    head: usize = 0,
    tail: usize = 0,
    count: std.atomic.Value(usize) = std.atomic.Value(usize).init(0),
    mutex: Thread.Mutex = .{},
    not_empty: Thread.Condition = .{},

    fn push(self: *WorkerQueue, stream: net.Stream) void {
        const c = self.count.load(.monotonic);
        if (c >= CAP) { stream.close(); return; }
        self.items[self.tail] = stream;
        self.tail = (self.tail + 1) % CAP;
        _ = self.count.fetchAdd(1, .release);
        // Wake worker if sleeping
        self.mutex.lock();
        self.not_empty.signal();
        self.mutex.unlock();
    }

    fn pop(self: *WorkerQueue) net.Stream {
        // Fast path: check without lock
        while (self.count.load(.acquire) == 0) {
            self.mutex.lock();
            // Re-check under lock to avoid missed wakeup
            if (self.count.load(.acquire) == 0) {
                self.not_empty.wait(&self.mutex);
            }
            self.mutex.unlock();
        }
        const s = self.items[self.head];
        self.head = (self.head + 1) % CAP;
        _ = self.count.fetchSub(1, .release);
        return s;
    }
};

const MAX_WORKERS = 64;
var queues: [MAX_WORKERS]WorkerQueue = [_]WorkerQueue{.{}} ** MAX_WORKERS;
var num_workers: usize = 0;

fn workerFn(id: usize) void {
    while (true) {
        const stream = queues[id].pop();
        handleConnection(stream);
    }
}

pub fn main() !void {
    const port: u16 = 8080;
    const cpu_count = Thread.getCpuCount() catch 4;
    num_workers = cpu_count;

    std.debug.print("=== Zag HTTP Server (sharded queues) ===\n", .{});
    std.debug.print("Workers: {d} | Queues: {d} (one per worker)\n", .{ num_workers, num_workers });
    std.debug.print("wrk -t8 -c1000 -d10s http://127.0.0.1:{d}/\n\n", .{port});

    // Stats
    _ = try Thread.spawn(.{}, struct {
        fn run() void {
            var last: u64 = 0;
            while (true) {
                std.Thread.sleep(1_000_000_000);
                const cur = total_requests.load(.monotonic);
                std.debug.print("[stats] {d} req/s | {d} total\n", .{ cur - last, cur });
                last = cur;
            }
        }
    }.run, .{});

    // Workers
    for (0..num_workers) |i| {
        _ = try Thread.spawn(.{}, workerFn, .{i});
    }

    // Accept — round-robin across worker queues
    const addr = net.Address.parseIp4("0.0.0.0", port) catch return;
    const sockfd = posix.socket(posix.AF.INET, posix.SOCK.STREAM, 0) catch return;
    posix.setsockopt(sockfd, posix.SOL.SOCKET, posix.SO.REUSEADDR, &std.mem.toBytes(@as(c_int, 1))) catch {};
    posix.bind(sockfd, &addr.any, addr.getOsSockLen()) catch return;
    posix.listen(sockfd, 4096) catch return;

    var next_worker: usize = 0;
    while (true) {
        var client_addr: posix.sockaddr = undefined;
        var addr_len: posix.socklen_t = @sizeOf(posix.sockaddr);
        const fd = posix.accept(sockfd, &client_addr, &addr_len, 0) catch continue;
        queues[next_worker].push(.{ .handle = fd });
        next_worker = (next_worker + 1) % num_workers;
    }
}
