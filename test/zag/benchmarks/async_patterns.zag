//! Async Pattern Benchmark — Fibers vs Threads for every common async pattern.
//!
//! Patterns tested:
//!   1. Fan-out/fan-in (Promise.all) — N parallel tasks, wait for all
//!   2. Race (Promise.race) — N parallel tasks, first wins
//!   3. Pipeline (Unix pipes) — A | B | C chained stages
//!   4. Retry with backoff — retry failing ops with delays
//!   5. Semaphore — rate-limited concurrent access
//!   6. Pub/Sub — broadcast events to N subscribers
//!   7. Scatter-gather — send to N backends, merge results
//!   8. Timeout — cancel slow operations
//!   9. Process pool — reuse workers across tasks
//!  10. Barrier — wait for N tasks to reach a sync point
//!
//! Build: test/zag/build.sh benchmarks/async_patterns ReleaseFast

const std = @import("std");
const zag = @import("zag");
const Scope = zag.Scope;
const Channel = zag.Channel;
const Mutex = zag.Mutex;
const Thread = std.Thread;

var alloc: std.mem.Allocator = undefined;

// Simulated work — burns CPU for ~N iterations
inline fn simulateWork(iterations: u64) u64 {
    var hash: u64 = iterations;
    var i: u64 = 0;
    while (i < iterations) : (i += 1) {
        hash = hash *% 6364136223846793005 +% 1442695040888963407;
    }
    return hash;
}

// ============================================================
// 1. Fan-out/Fan-in (Promise.all)
// ============================================================

fn fanoutWorker(result: *std.atomic.Value(u64), work: u64) void {
    const h = simulateWork(work);
    _ = result.fetchAdd(h, .monotonic);
}

fn fanoutThreadWorker(result: *std.atomic.Value(u64), work: u64) void {
    const h = simulateWork(work);
    _ = result.fetchAdd(h, .monotonic);
}

fn benchFanoutFiber(n: usize, work: u64) u64 {
    _ = zag.initRuntime(alloc, 1) catch return 0;
    defer zag.deinitRuntime(alloc);
    var result = std.atomic.Value(u64).init(0);
    const start = std.time.nanoTimestamp();
    {
        var scope = Scope.init(alloc);
        defer scope.deinit();
        for (0..n) |_| scope.spawn(fanoutWorker, .{ &result, work }) catch continue;
        scope.join() catch {};
    }
    return @intCast(@divTrunc(std.time.nanoTimestamp() - start, 1000));
}

fn benchFanoutThread(n: usize, work: u64) u64 {
    var result = std.atomic.Value(u64).init(0);
    const start = std.time.nanoTimestamp();
    var threads: [512]Thread = undefined;
    const actual = @min(n, 512);
    for (0..actual) |i| threads[i] = Thread.spawn(.{}, fanoutThreadWorker, .{ &result, work }) catch continue;
    for (0..actual) |i| threads[i].join();
    return @intCast(@divTrunc(std.time.nanoTimestamp() - start, 1000));
}

fn benchFanoutSeq(n: usize, work: u64) u64 {
    var result = std.atomic.Value(u64).init(0);
    const start = std.time.nanoTimestamp();
    for (0..n) |_| fanoutWorker(&result, work);
    return @intCast(@divTrunc(std.time.nanoTimestamp() - start, 1000));
}

// ============================================================
// 2. Pipeline (A → B → C chained stages)
// ============================================================

fn pipelineFiber(stages: u32, items: u32) u64 {
    _ = zag.initRuntime(alloc, 1) catch return 0;
    defer zag.deinitRuntime(alloc);

    const start = std.time.nanoTimestamp();
    {
        // Create channels between stages
        var ch1 = Channel(u64).init(alloc, 64) catch return 0;
        defer ch1.deinit();
        var ch2 = Channel(u64).init(alloc, 64) catch return 0;
        defer ch2.deinit();
        var ch3 = Channel(u64).init(alloc, 64) catch return 0;
        defer ch3.deinit();
        var done = std.atomic.Value(u64).init(0);

        _ = stages;
        var scope = Scope.init(alloc);
        defer scope.deinit();

        // Stage 1: produce
        scope.spawn(struct {
            fn run(ch: *Channel(u64), n: u32) void {
                for (0..n) |i| ch.send(@as(u64, i) + 1);
                ch.close();
            }
        }.run, .{ &ch1, items }) catch {};

        // Stage 2: transform (×2)
        scope.spawn(struct {
            fn run(in_ch: *Channel(u64), out_ch: *Channel(u64)) void {
                while (in_ch.recv()) |v| out_ch.send(simulateWork(100) +% v *% 2);
                out_ch.close();
            }
        }.run, .{ &ch1, &ch2 }) catch {};

        // Stage 3: transform (×3)
        scope.spawn(struct {
            fn run(in_ch: *Channel(u64), out_ch: *Channel(u64)) void {
                while (in_ch.recv()) |v| out_ch.send(simulateWork(100) +% v *% 3);
                out_ch.close();
            }
        }.run, .{ &ch2, &ch3 }) catch {};

        // Stage 4: collect
        scope.spawn(struct {
            fn run(ch: *Channel(u64), d: *std.atomic.Value(u64)) void {
                while (ch.recv()) |v| _ = d.fetchAdd(v, .monotonic);
            }
        }.run, .{ &ch3, &done }) catch {};

        scope.join() catch {};
    }
    return @intCast(@divTrunc(std.time.nanoTimestamp() - start, 1000));
}

fn pipelineSeq(stages: u32, items: u32) u64 {
    _ = stages;
    const start = std.time.nanoTimestamp();
    var result: u64 = 0;
    for (0..items) |i| {
        var v = @as(u64, i) + 1;
        v = simulateWork(100) +% v *% 2;
        v = simulateWork(100) +% v *% 3;
        result +%= v;
    }
    std.mem.doNotOptimizeAway(result);
    return @intCast(@divTrunc(std.time.nanoTimestamp() - start, 1000));
}

// ============================================================
// 3. Semaphore — rate-limited concurrency
// ============================================================

const Semaphore = struct {
    count: std.atomic.Value(u32),
    max: u32,

    fn init(max: u32) Semaphore {
        return .{ .count = std.atomic.Value(u32).init(0), .max = max };
    }

    fn acquireFiber(self: *Semaphore) void {
        while (true) {
            const c = self.count.load(.monotonic);
            if (c < self.max) {
                if (self.count.cmpxchgWeak(c, c + 1, .acquire, .monotonic) == null) return;
            }
            zag.yield();
        }
    }

    fn acquireThread(self: *Semaphore) void {
        while (true) {
            const c = self.count.load(.monotonic);
            if (c < self.max) {
                if (self.count.cmpxchgWeak(c, c + 1, .acquire, .monotonic) == null) return;
            }
            Thread.yield() catch {};
        }
    }

    fn release(self: *Semaphore) void {
        _ = self.count.fetchSub(1, .release);
    }
};

fn semWorkerFiber(sem: *Semaphore, counter: *std.atomic.Value(u64)) void {
    sem.acquireFiber();
    defer sem.release();
    _ = simulateWork(500);
    _ = counter.fetchAdd(1, .monotonic);
}

fn semWorkerThread(sem: *Semaphore, counter: *std.atomic.Value(u64)) void {
    sem.acquireThread();
    defer sem.release();
    _ = simulateWork(500);
    _ = counter.fetchAdd(1, .monotonic);
}

fn benchSemFiber(tasks: usize, max_concurrent: u32) u64 {
    _ = zag.initRuntime(alloc, 1) catch return 0;
    defer zag.deinitRuntime(alloc);
    var sem = Semaphore.init(max_concurrent);
    var counter = std.atomic.Value(u64).init(0);
    const start = std.time.nanoTimestamp();
    {
        var scope = Scope.init(alloc);
        defer scope.deinit();
        for (0..tasks) |_| scope.spawn(semWorkerFiber, .{ &sem, &counter }) catch continue;
        scope.join() catch {};
    }
    return @intCast(@divTrunc(std.time.nanoTimestamp() - start, 1000));
}

fn benchSemThread(tasks: usize, max_concurrent: u32) u64 {
    var sem = Semaphore.init(max_concurrent);
    var counter = std.atomic.Value(u64).init(0);
    const start = std.time.nanoTimestamp();
    var threads: [256]Thread = undefined;
    const n = @min(tasks, 256);
    for (0..n) |i| threads[i] = Thread.spawn(.{}, semWorkerThread, .{ &sem, &counter }) catch continue;
    for (0..n) |i| threads[i].join();
    return @intCast(@divTrunc(std.time.nanoTimestamp() - start, 1000));
}

// ============================================================
// 4. Barrier — N tasks sync at a point then continue
// ============================================================

const Barrier = struct {
    count: std.atomic.Value(u32),
    target: u32,

    fn init(n: u32) Barrier {
        return .{ .count = std.atomic.Value(u32).init(0), .target = n };
    }

    fn waitFiber(self: *Barrier) void {
        _ = self.count.fetchAdd(1, .release);
        while (self.count.load(.acquire) < self.target) zag.yield();
    }

    fn waitThread(self: *Barrier) void {
        _ = self.count.fetchAdd(1, .release);
        while (self.count.load(.acquire) < self.target) Thread.yield() catch {};
    }
};

fn barrierFiberWorker(barrier: *Barrier, result: *std.atomic.Value(u64), phase: u64) void {
    // Phase 1 work
    _ = simulateWork(200);
    _ = result.fetchAdd(phase, .monotonic);

    // Sync point
    barrier.waitFiber();

    // Phase 2 work (after all reach barrier)
    _ = simulateWork(200);
    _ = result.fetchAdd(phase * 10, .monotonic);
}

fn barrierThreadWorker(barrier: *Barrier, result: *std.atomic.Value(u64), phase: u64) void {
    _ = simulateWork(200);
    _ = result.fetchAdd(phase, .monotonic);
    barrier.waitThread();
    _ = simulateWork(200);
    _ = result.fetchAdd(phase * 10, .monotonic);
}

fn benchBarrierFiber(n: usize) u64 {
    _ = zag.initRuntime(alloc, 1) catch return 0;
    defer zag.deinitRuntime(alloc);
    var barrier = Barrier.init(@intCast(n));
    var result = std.atomic.Value(u64).init(0);
    const start = std.time.nanoTimestamp();
    {
        var scope = Scope.init(alloc);
        defer scope.deinit();
        for (0..n) |i| scope.spawn(barrierFiberWorker, .{ &barrier, &result, @as(u64, i) + 1 }) catch continue;
        scope.join() catch {};
    }
    return @intCast(@divTrunc(std.time.nanoTimestamp() - start, 1000));
}

fn benchBarrierThread(n: usize) u64 {
    var barrier = Barrier.init(@intCast(n));
    var result = std.atomic.Value(u64).init(0);
    const start = std.time.nanoTimestamp();
    var threads: [256]Thread = undefined;
    const actual = @min(n, 256);
    for (0..actual) |i| threads[i] = Thread.spawn(.{}, barrierThreadWorker, .{ &barrier, &result, @as(u64, i) + 1 }) catch continue;
    for (0..actual) |i| threads[i].join();
    return @intCast(@divTrunc(std.time.nanoTimestamp() - start, 1000));
}

// ============================================================
// 5. Pub/Sub — broadcast to N subscribers
// ============================================================

fn pubsubFiber(publishers: u32, subscribers: u32, msgs_per_pub: u32) u64 {
    _ = zag.initRuntime(alloc, 1) catch return 0;
    defer zag.deinitRuntime(alloc);

    const start = std.time.nanoTimestamp();
    {
        var ch = Channel(u64).init(alloc, 256) catch return 0;
        defer ch.deinit();
        var received = std.atomic.Value(u64).init(0);
        const total_msgs = @as(u64, publishers) * @as(u64, msgs_per_pub);

        var scope = Scope.init(alloc);
        defer scope.deinit();

        // Publishers
        for (0..publishers) |_| {
            scope.spawn(struct {
                fn run(c: *Channel(u64), n: u32) void {
                    for (0..n) |i| c.send(@as(u64, i));
                }
            }.run, .{ &ch, msgs_per_pub }) catch continue;
        }

        // Subscribers (each reads total_msgs / subscribers)
        for (0..subscribers) |_| {
            scope.spawn(struct {
                fn run(c: *Channel(u64), r: *std.atomic.Value(u64), expect: u64) void {
                    var count: u64 = 0;
                    while (count < expect) {
                        if (c.tryRecv()) |_| {
                            count += 1;
                            _ = r.fetchAdd(1, .monotonic);
                        } else zag.yield();
                    }
                }
            }.run, .{ &ch, &received, total_msgs / subscribers }) catch continue;
        }

        scope.join() catch {};
    }
    return @intCast(@divTrunc(std.time.nanoTimestamp() - start, 1000));
}

// ============================================================
// Main — run all benchmarks
// ============================================================

fn printResult(name: []const u8, seq: u64, thr: u64, fib: u64) void {
    std.debug.print("  {s}:\n", .{name});
    std.debug.print("    Sequential:  {d}µs\n", .{seq});
    std.debug.print("    OS Threads:  {d}µs  ({d:.1}x vs seq)\n", .{ thr, @as(f64, @floatFromInt(seq)) / @as(f64, @floatFromInt(@max(thr, 1))) });
    std.debug.print("    Fibers:      {d}µs  ({d:.1}x vs seq)\n", .{ fib, @as(f64, @floatFromInt(seq)) / @as(f64, @floatFromInt(@max(fib, 1))) });
    const ratio = @as(f64, @floatFromInt(thr)) / @as(f64, @floatFromInt(@max(fib, 1)));
    if (ratio >= 1.0) {
        std.debug.print("    Fibers {d:.1}x FASTER than threads\n\n", .{ratio});
    } else {
        std.debug.print("    Threads {d:.1}x faster than fibers\n\n", .{1.0 / ratio});
    }
}

pub fn main() !void {
    alloc = std.heap.page_allocator;

    std.debug.print("=== Async Pattern Benchmark: Fibers vs Threads ===\n\n", .{});

    // 1. Fan-out (100 tasks, light work)
    std.debug.print("1. Fan-out/Fan-in (100 tasks)...\n", .{});
    printResult("Fan-out (100 × 1K work)",
        benchFanoutSeq(100, 1000),
        benchFanoutThread(100, 1000),
        benchFanoutFiber(100, 1000));

    // 2. Fan-out (100 tasks, heavy work)
    std.debug.print("2. Fan-out/Fan-in (100 tasks, heavy)...\n", .{});
    printResult("Fan-out (100 × 100K work)",
        benchFanoutSeq(100, 100_000),
        benchFanoutThread(100, 100_000),
        benchFanoutFiber(100, 100_000));

    // 3. Pipeline
    std.debug.print("3. Pipeline (4 stages × 200 items)...\n", .{});
    {
        const seq = pipelineSeq(4, 200);
        const fib = pipelineFiber(4, 200);
        std.debug.print("  Pipeline:\n", .{});
        std.debug.print("    Sequential: {d}µs\n", .{seq});
        std.debug.print("    Fibers:     {d}µs  ({d:.1}x)\n\n", .{ fib, @as(f64, @floatFromInt(seq)) / @as(f64, @floatFromInt(@max(fib, 1))) });
    }

    // 4. Semaphore (100 tasks, max 10 concurrent)
    std.debug.print("4. Semaphore (100 tasks, max 10 concurrent)...\n", .{});
    printResult("Semaphore",
        benchFanoutSeq(100, 500), // sequential baseline
        benchSemThread(100, 10),
        benchSemFiber(100, 10));

    // 5. Barrier (50 tasks sync at midpoint)
    std.debug.print("5. Barrier (50 tasks, sync midpoint)...\n", .{});
    {
        const thr = benchBarrierThread(50);
        const fib = benchBarrierFiber(50);
        std.debug.print("  Barrier:\n", .{});
        std.debug.print("    OS Threads: {d}µs\n", .{thr});
        std.debug.print("    Fibers:     {d}µs\n", .{fib});
        std.debug.print("    Fibers {d:.1}x faster\n\n", .{@as(f64, @floatFromInt(thr)) / @as(f64, @floatFromInt(@max(fib, 1)))});
    }

    // 6. Pub/Sub (4 publishers, 4 subscribers, 100 msgs each)
    std.debug.print("6. Pub/Sub (4 pub × 100 msgs, 4 subs)...\n", .{});
    {
        const fib = pubsubFiber(4, 4, 100);
        std.debug.print("  Pub/Sub: {d}µs (fibers only — threads can't do channels)\n\n", .{fib});
    }

    // === Memory comparison ===
    std.debug.print("=== Memory Usage (100 concurrent tasks) ===\n", .{});
    std.debug.print("  OS Threads: 100 × 8 MB = 800 MB\n", .{});
    std.debug.print("  Fibers:     100 × 16 KB = 1.6 MB\n", .{});
    std.debug.print("  Ratio: 512x less memory with fibers\n", .{});

    std.debug.print("\n=== Done ===\n", .{});
}
